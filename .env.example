CLECMAS_ENV=local
CLECMAS_APP_NAME=clecmas
CLECMAS_DEBUG=false

CLECMAS_DB_HOST=db
CLECMAS_DB_PORT=5432
CLECMAS_DB_NAME=clecmas
CLECMAS_DB_USER=clecmas_app
CLECMAS_DB_PASSWORD_FILE=/run/secrets/db_password

CLECMAS_EVIDENCE_ROOT=/var/lib/clecmas/evidence
CLECMAS_EXPORT_ROOT=/var/lib/clecmas/exports
CLECMAS_BACKUP_ROOT=/var/lib/clecmas/backups

CLECMAS_SMTP_HOST=smtp.example.com
CLECMAS_SMTP_PORT=587
CLECMAS_SMTP_USER=alerts@example.com
CLECMAS_SMTP_PASSWORD_FILE=/run/secrets/smtp_password
CLECMAS_ALERT_LEAD_DAYS=120,90,60,30,14,7

CLECMAS_AI_ENABLED=false
CLECMAS_LLM_PROVIDER=
OPENAI_API_KEY_FILE=/run/secrets/openai_api_key
ANTHROPIC_API_KEY_FILE=/run/secrets/anthropic_api_key
GEMINI_API_KEY_FILE=/run/secrets/gemini_api_key
AZURE_OPENAI_API_KEY_FILE=/run/secrets/azure_openai_api_key
AZURE_OPENAI_ENDPOINT=
M365_COPILOT_RETRIEVAL_ENABLED=false

CLECMAS_MAX_UPLOAD_MB=25
CLECMAS_ENABLE_CLAMAV=false
CLECMAS_RETENTION_DISPOSITION_REQUIRES_REVIEW=true
CLECMAS_RULE_REFRESH_CRON=0 5 * * 1
CLECMAS_BACKUP_CRON=0 2 * * *
